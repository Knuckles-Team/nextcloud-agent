{
  "mcpServers": {
    "nextcloud-agent": {
      "command": "uv",
      "args": [
        "run",
        "nextcloud-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "CALENDARTOOL": "True",
        "CONTACTSTOOL": "True",
        "FILESTOOL": "True",
        "NEXTCLOUD_PASSWORD": "your_password",
        "NEXTCLOUD_URL": "https://nextcloud.example.com",
        "NEXTCLOUD_USERNAME": "your_username",
        "SHARINGTOOL": "True",
        "USERTOOL": "True"
      }
    }
  }
}
